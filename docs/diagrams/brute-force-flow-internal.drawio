        <mxCell id="note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontSize=11;align=left;spacingLeft=10;fontColor=#7c2d12;" value="보안 메모: ALTCHA_HMAC_KEY 는 환경변수 주입(데모 기본값 시 경고 로그) · 인메모리 단일 서버 가정 · enumeration 방어를 위해 실패 응답 메시지는 모두 동일하게 일반화 · replay 방지로 payload 는 1회용(프론트가 제출마다 재발급)" vertex="1">
