<mxfile host="Electron" agent="claude-code">
  <diagram name="무차별 대입 방어 흐름 (개발용)" id="bf-internal">
    <mxGraphModel dx="1517" dy="1164" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="950" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#111827;" value="로그인 무차별 대입 방어 처리 흐름 — 내부 개발용" vertex="1">
          <mxGeometry height="36" width="740" x="280" y="14" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=12;fontColor=#6b7280;" value="Next.js 16 (App Router) + Spring Boot 3.5 / Java 21  |  방어계층: (0) IP Rate Limit → (1) Altcha PoW + replay 방지 → (2) 자격증명 확인" vertex="1">
          <mxGeometry height="22" width="980" x="160" y="50" as="geometry" />
        </mxCell>
        <mxCell id="laneFE" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#93c5fd;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#1d4ed8;spacingTop=8;" value="Frontend — Next.js / React (브라우저)" vertex="1">
          <mxGeometry height="820" width="520" x="40" y="90" as="geometry" />
        </mxCell>
        <mxCell id="laneBE" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#86efac;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#15803d;spacingTop=8;" value="Backend — Spring Boot (com.example.bruteforce)" vertex="1">
          <mxGeometry height="820" width="660" x="600" y="90" as="geometry" />
        </mxCell>
        <mxCell id="f1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=11;align=left;spacingLeft=10;fontColor=#1e3a8a;" value="&lt;b&gt;AltchaWidget.tsx&lt;/b&gt;&#xa;마운트 시 import(&#39;altcha&#39;) 동적 로드 (CDN 아님, 외부통신 0)&#xa;SSR 회피: ready 상태 후 &lt;altcha-widget&gt; 렌더" vertex="1">
          <mxGeometry height="64" width="480" x="60" y="130" as="geometry" />
        </mxCell>
        <mxCell id="f2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=11;align=left;spacingLeft=10;fontColor=#1e3a8a;" value="위젯이 challengeurl 호출&#xa;&lt;b&gt;GET /api/captcha/challenge&lt;/b&gt; (Next rewrites → :8080)" vertex="1">
          <mxGeometry height="50" width="480" x="60" y="214" as="geometry" />
        </mxCell>
        <mxCell id="f3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=11;align=left;spacingLeft=10;fontColor=#1e3a8a;" value="&lt;b&gt;사용자가 체크박스 클릭 (수동)&lt;/b&gt;&#xa;브라우저가 PoW 풀이 → statechange &#39;verified&#39;&#xa;onVerified(payload) → LoginForm 의 altcha state 저장" vertex="1">
          <mxGeometry height="64" width="480" x="60" y="296" as="geometry" />
        </mxCell>
        <mxCell id="f4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=11;align=left;spacingLeft=10;fontColor=#1e3a8a;" value="&lt;b&gt;LoginForm.onSubmit&lt;/b&gt;&#xa;가드: !altcha 면 &quot;자동입력 방지 인증을 완료해 주세요&quot;&#xa;&lt;b&gt;POST /api/auth/login&lt;/b&gt; { username, password, altcha }" vertex="1">
          <mxGeometry height="64" width="480" x="60" y="392" as="geometry" />
        </mxCell>
        <mxCell id="f5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=11;align=left;spacingLeft=10;fontColor=#1e3a8a;" value="&lt;b&gt;응답 처리&lt;/b&gt;&#xa;• 429 → Retry-After(초)로 카운트다운 &quot;시도 횟수 초과 · N초 후 재시도&quot;&#xa;• 400 → &quot;캡차 검증에 실패했습니다&quot;&#xa;• 401 → &quot;아이디 또는 비밀번호가 올바르지 않습니다&quot;&#xa;• 200 → &quot;로그인 성공&quot;" vertex="1">
          <mxGeometry height="110" width="480" x="60" y="560" as="geometry" />
        </mxCell>
        <mxCell id="f6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2ff;strokeColor=#6366f1;fontSize=11;align=left;spacingLeft=10;fontColor=#3730a3;" value="&lt;b&gt;finally&lt;/b&gt;: setAltcha(&#39;&#39;) + widgetKey++&#xa;&lt;AltchaWidget key={widgetKey}&gt; 재마운트 → 미인증 상태로 복귀&#xa;다음 시도는 사용자가 재클릭해 &lt;b&gt;새 1회용 payload&lt;/b&gt; 발급" vertex="1">
          <mxGeometry height="64" width="480" x="60" y="700" as="geometry" />
        </mxCell>
        <mxCell id="b0" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=11;align=left;spacingLeft=10;fontColor=#14532d;" value="&lt;b&gt;CaptchaController&lt;/b&gt; @GetMapping /captcha/challenge&#xa;Altcha.createChallenge(hmacKey, maxNumber, expiresInSeconds)&#xa;→ { algorithm, challenge, salt, signature, maxnumber } JSON&#xa;로컬 HMAC/해시 연산만 (외부통신 0). 차단 대상 제외(/auth/** 만 인터셉트)" vertex="1">
          <mxGeometry height="78" width="620" x="620" y="130" as="geometry" />
        </mxCell>
        <mxCell id="b1" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;fontSize=11;fontColor=#713f12;" value="&lt;b&gt;(0) RateLimitInterceptor.preHandle&lt;/b&gt; (/auth/**)&#xa;ClientIpResolver.resolve (X-Forwarded-For 우선)&#xa;rateLimitService.isBlocked(ip) ?" vertex="1">
          <mxGeometry height="120" width="280" x="680" y="364" as="geometry" />
        </mxCell>
        <mxCell id="b1yes" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=11;align=left;spacingLeft=10;fontColor=#92400e;" value="&lt;b&gt;HTTP 429&lt;/b&gt; + Retry-After: 남은 차단 초&#xa;본문: 일반화 메시지만&#xa;return false (비즈니스 진입 차단)" vertex="1">
          <mxGeometry height="88" width="200" x="1040" y="380" as="geometry" />
        </mxCell>
        <mxCell id="b2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=11;align=left;spacingLeft=10;fontColor=#14532d;" value="&lt;b&gt;(1) AuthController.login → AltchaVerifier.verify(payload)&lt;/b&gt;&#xa;• Altcha.verifySolution(payload, hmacKey, checkExpires=true) — PoW+서명+만료&#xa;• replay 방지: usedSolutions.putIfAbsent(sha256(payload)) — 1회용&#xa;실패/재사용 → &lt;b&gt;HTTP 400&lt;/b&gt; &quot;캡차 검증에 실패&quot;" vertex="1">
          <mxGeometry height="86" width="620" x="620" y="540" as="geometry" />
        </mxCell>
        <mxCell id="b3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=11;align=left;spacingLeft=10;fontColor=#14532d;" value="&lt;b&gt;(2) AuthService.matches(username, password)&lt;/b&gt;&#xa;데모 계정 단순 비교 (enumeration 방어: 동일 비교 경로)&#xa;불일치 → rateLimitService.recordFailure(ip) → &lt;b&gt;HTTP 401&lt;/b&gt; (동일 메시지)&#xa;일치 → rateLimitService.reset(ip) → &lt;b&gt;HTTP 200&lt;/b&gt; + demo token" vertex="1">
          <mxGeometry height="86" width="620" x="620" y="660" as="geometry" />
        </mxCell>
        <mxCell id="b4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=11;align=left;spacingLeft=10;fontColor=#92400e;" value="&lt;b&gt;RateLimitService (인메모리 ConcurrentHashMap)&lt;/b&gt;&#xa;windowSeconds 내 실패 ≥ maxFailures(5) → blockStage++&#xa;blockedUntil = now + 단계별 차단(15s → 30s → 60s 상한, 점진 상승)" vertex="1">
          <mxGeometry height="76" width="430" x="620" y="780" as="geometry" />
        </mxCell>
        <mxCell id="b5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#64748b;fontSize=11;align=left;spacingLeft=10;fontColor=#334155;" value="&lt;b&gt;@Scheduled 만료 정리&lt;/b&gt;&#xa;RateLimit: 30s 주기&#xa;Altcha used: 60s 주기&#xa;(메모리 누수 방지)" vertex="1">
          <mxGeometry height="92" width="170" x="1070" y="772" as="geometry" />
        </mxCell>
