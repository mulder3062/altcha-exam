<mxfile host="app.diagrams.net" agent="claude-code" version="24.0.0">
  <diagram name="무차별 대입 방어 흐름 (개발용)" id="bf-internal">
    <mxGraphModel dx="1100" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="950" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 제목 -->
        <mxCell id="title" value="로그인 무차별 대입 방어 처리 흐름 &#8212; 내부 개발용" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="280" y="14" width="740" height="36" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Next.js 16 (App Router) + Spring Boot 3.5 / Java 21 &#160;|&#160; 방어계층: (0) IP Rate Limit &#8594; (1) Altcha PoW + replay 방지 &#8594; (2) 자격증명 확인" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=12;fontColor=#6b7280;" vertex="1" parent="1">
          <mxGeometry x="160" y="50" width="980" height="22" as="geometry" />
        </mxCell>

        <!-- ===== Frontend 레인 ===== -->
        <mxCell id="laneFE" value="Frontend &#8212; Next.js / React (브라우저)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#93c5fd;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#1d4ed8;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="520" height="820" as="geometry" />
        </mxCell>

        <!-- ===== Backend 레인 ===== -->
        <mxCell id="laneBE" value="Backend &#8212; Spring Boot (com.example.bruteforce)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#86efac;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#15803d;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="600" y="90" width="660" height="820" as="geometry" />
        </mxCell>

        <!-- ===== Frontend 노드 ===== -->
        <mxCell id="f1" value="&lt;b&gt;AltchaWidget.tsx&lt;/b&gt;&#10;마운트 시 import('altcha') 동적 로드 (CDN 아님, 외부통신 0)&#10;SSR 회피: ready 상태 후 &lt;altcha-widget&gt; 렌더" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=11;align=left;spacingLeft=10;fontColor=#1e3a8a;" vertex="1" parent="1">
          <mxGeometry x="60" y="130" width="480" height="64" as="geometry" />
        </mxCell>
        <mxCell id="f2" value="위젯이 challengeurl 호출&#10;&lt;b&gt;GET /api/captcha/challenge&lt;/b&gt; (Next rewrites &#8594; :8080)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=11;align=left;spacingLeft=10;fontColor=#1e3a8a;" vertex="1" parent="1">
          <mxGeometry x="60" y="214" width="480" height="50" as="geometry" />
        </mxCell>
        <mxCell id="f3" value="&lt;b&gt;사용자가 체크박스 클릭 (수동)&lt;/b&gt;&#10;브라우저가 PoW 풀이 &#8594; statechange 'verified'&#10;onVerified(payload) &#8594; LoginForm 의 altcha state 저장" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=11;align=left;spacingLeft=10;fontColor=#1e3a8a;" vertex="1" parent="1">
          <mxGeometry x="60" y="296" width="480" height="64" as="geometry" />
        </mxCell>
        <mxCell id="f4" value="&lt;b&gt;LoginForm.onSubmit&lt;/b&gt;&#10;가드: !altcha 면 &#34;자동입력 방지 인증을 완료해 주세요&#34;&#10;&lt;b&gt;POST /api/auth/login&lt;/b&gt; { username, password, altcha }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=11;align=left;spacingLeft=10;fontColor=#1e3a8a;" vertex="1" parent="1">
          <mxGeometry x="60" y="392" width="480" height="64" as="geometry" />
        </mxCell>
        <mxCell id="f5" value="&lt;b&gt;응답 처리&lt;/b&gt;&#10;&#8226; 429 &#8594; Retry-After(초)로 카운트다운 &#34;시도 횟수 초과 · N초 후 재시도&#34;&#10;&#8226; 400 &#8594; &#34;캡차 검증에 실패했습니다&#34;&#10;&#8226; 401 &#8594; &#34;아이디 또는 비밀번호가 올바르지 않습니다&#34;&#10;&#8226; 200 &#8594; &#34;로그인 성공&#34;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=11;align=left;spacingLeft=10;fontColor=#1e3a8a;" vertex="1" parent="1">
          <mxGeometry x="60" y="560" width="480" height="110" as="geometry" />
        </mxCell>
        <mxCell id="f6" value="&lt;b&gt;finally&lt;/b&gt;: setAltcha('') + widgetKey++&#10;&lt;AltchaWidget key={widgetKey}&gt; 재마운트 &#8594; 미인증 상태로 복귀&#10;다음 시도는 사용자가 재클릭해 &lt;b&gt;새 1회용 payload&lt;/b&gt; 발급" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2ff;strokeColor=#6366f1;fontSize=11;align=left;spacingLeft=10;fontColor=#3730a3;" vertex="1" parent="1">
          <mxGeometry x="60" y="700" width="480" height="64" as="geometry" />
        </mxCell>

        <!-- ===== Backend 노드 ===== -->
        <mxCell id="b0" value="&lt;b&gt;CaptchaController&lt;/b&gt; @GetMapping /captcha/challenge&#10;Altcha.createChallenge(hmacKey, maxNumber, expiresInSeconds)&#10;&#8594; { algorithm, challenge, salt, signature, maxnumber } JSON&#10;로컬 HMAC/해시 연산만 (외부통신 0). 차단 대상 제외(/auth/** 만 인터셉트)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=11;align=left;spacingLeft=10;fontColor=#14532d;" vertex="1" parent="1">
          <mxGeometry x="620" y="130" width="620" height="78" as="geometry" />
        </mxCell>

        <mxCell id="b1" value="&lt;b&gt;(0) RateLimitInterceptor.preHandle&lt;/b&gt; (/auth/**)&#10;ClientIpResolver.resolve (X-Forwarded-For 우선)&#10;rateLimitService.isBlocked(ip) ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;fontSize=11;fontColor=#713f12;" vertex="1" parent="1">
          <mxGeometry x="700" y="380" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="b1yes" value="&lt;b&gt;HTTP 429&lt;/b&gt; + Retry-After: 남은 차단 초&#10;본문: 일반화 메시지만&#10;return false (비즈니스 진입 차단)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=11;align=left;spacingLeft=10;fontColor=#92400e;" vertex="1" parent="1">
          <mxGeometry x="1010" y="396" width="230" height="88" as="geometry" />
        </mxCell>

        <mxCell id="b2" value="&lt;b&gt;(1) AuthController.login &#8594; AltchaVerifier.verify(payload)&lt;/b&gt;&#10;&#8226; Altcha.verifySolution(payload, hmacKey, checkExpires=true) &#8212; PoW+서명+만료&#10;&#8226; replay 방지: usedSolutions.putIfAbsent(sha256(payload)) &#8212; 1회용&#10;실패/재사용 &#8594; &lt;b&gt;HTTP 400&lt;/b&gt; &#34;캡차 검증에 실패&#34;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=11;align=left;spacingLeft=10;fontColor=#14532d;" vertex="1" parent="1">
          <mxGeometry x="620" y="540" width="620" height="86" as="geometry" />
        </mxCell>

        <mxCell id="b3" value="&lt;b&gt;(2) AuthService.matches(username, password)&lt;/b&gt;&#10;데모 계정 단순 비교 (enumeration 방어: 동일 비교 경로)&#10;불일치 &#8594; rateLimitService.recordFailure(ip) &#8594; &lt;b&gt;HTTP 401&lt;/b&gt; (동일 메시지)&#10;일치 &#8594; rateLimitService.reset(ip) &#8594; &lt;b&gt;HTTP 200&lt;/b&gt; + demo token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=11;align=left;spacingLeft=10;fontColor=#14532d;" vertex="1" parent="1">
          <mxGeometry x="620" y="660" width="620" height="86" as="geometry" />
        </mxCell>

        <mxCell id="b4" value="&lt;b&gt;RateLimitService (인메모리 ConcurrentHashMap)&lt;/b&gt;&#10;windowSeconds 내 실패 &#8805; maxFailures(5) &#8594; blockStage++&#10;blockedUntil = now + 단계별 차단(15s &#8594; 30s &#8594; 60s 상한, 점진 상승)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=11;align=left;spacingLeft=10;fontColor=#92400e;" vertex="1" parent="1">
          <mxGeometry x="620" y="780" width="430" height="76" as="geometry" />
        </mxCell>
        <mxCell id="b5" value="&lt;b&gt;@Scheduled 만료 정리&lt;/b&gt;&#10;RateLimit: 30s 주기&#10;Altcha used: 60s 주기&#10;(메모리 누수 방지)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#64748b;fontSize=11;align=left;spacingLeft=10;fontColor=#334155;" vertex="1" parent="1">
          <mxGeometry x="1070" y="772" width="170" height="92" as="geometry" />
        </mxCell>

        <!-- ===== Frontend 내부 흐름 ===== -->
        <mxCell id="ef1" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#2563eb;" edge="1" parent="1" source="f1" target="f2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ef2" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#2563eb;" edge="1" parent="1" source="f2" target="f3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ef3" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#2563eb;" edge="1" parent="1" source="f3" target="f4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ef4" value="응답 수신" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#2563eb;fontSize=10;fontColor=#1e40af;" edge="1" parent="1" source="f4" target="f5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ef5" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#6366f1;" edge="1" parent="1" source="f5" target="f6"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ef6" value="재시도 (재클릭)" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#6366f1;dashed=1;fontSize=10;fontColor=#4338ca;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="f6" target="f3"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ===== 교차 레인 흐름 ===== -->
        <mxCell id="x1" value="GET challenge" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#0ea5e9;fontSize=10;fontColor=#0369a1;" edge="1" parent="1" source="f2" target="b0"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="x2" value="challenge JSON" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#0ea5e9;dashed=1;fontSize=10;fontColor=#0369a1;" edge="1" parent="1" source="b0" target="f3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="x3" value="POST /auth/login" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#0ea5e9;fontSize=10;fontColor=#0369a1;" edge="1" parent="1" source="f4" target="b1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ===== Backend 내부 흐름 ===== -->
        <mxCell id="eb1yes" value="YES (차단 중)" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#d97706;fontSize=10;fontColor=#b45309;" edge="1" parent="1" source="b1" target="b1yes"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eb1no" value="NO (통과)" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#16a34a;fontSize=10;fontColor=#15803d;" edge="1" parent="1" source="b1" target="b2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eb2" value="캡차 통과" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#16a34a;fontSize=10;fontColor=#15803d;" edge="1" parent="1" source="b2" target="b3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eb3" value="실패 누적" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#d97706;dashed=1;fontSize=10;fontColor=#b45309;" edge="1" parent="1" source="b3" target="b4"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- 응답 반환(상태코드) → Frontend f5 -->
        <mxCell id="r429" value="429" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#d97706;dashed=1;fontSize=10;fontColor=#b45309;" edge="1" parent="1" source="b1yes" target="f5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="r400" value="400" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#dc2626;dashed=1;fontSize=10;fontColor=#b91c1c;" edge="1" parent="1" source="b2" target="f5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="r200" value="200 / 401" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#16a34a;dashed=1;fontSize=10;fontColor=#15803d;" edge="1" parent="1" source="b3" target="f5"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- 차단 단계가 인터셉터 판정에 반영 -->
        <mxCell id="eb4loop" value="다음 요청부터 isBlocked=true" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#d97706;dashed=1;fontSize=10;fontColor=#b45309;exitX=0;exitY=0.5;entryX=0;entryY=1;" edge="1" parent="1" source="b4" target="b1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- 노트 -->
        <mxCell id="note" value="보안 메모: ALTCHA_HMAC_KEY 는 환경변수 주입(데모 기본값 시 경고 로그) · 인메모리 단일 서버 가정 · enumeration 방어를 위해 실패 응답 메시지는 모두 동일하게 일반화 · replay 방지로 payload 는 1회용(프론트가 제출마다 재발급)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontSize=11;align=left;spacingLeft=10;fontColor=#7c2d12;" vertex="1" parent="1">
          <mxGeometry x="60" y="876" width="1180" height="26" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
